CREATE pipe_config SET name = $name, origin_connector = $origin_connector, origin_dsn = $origin_dsn, origin_credential = $origin_credential, trino_url = $trino_url, origin_config = $origin_config, targets = $targets, schedule = $schedule, delta = $delta, retry = $retry, filters = $filters, transforms = $transforms, links = $links, enabled = true, updated_at = time::now();
